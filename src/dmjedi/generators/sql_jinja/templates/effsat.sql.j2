{% endif -%}

MERGE INTO {{ effsat.name | q }} AS target
USING {{ ('stg_' ~ effsat.name) | q }} AS source
ON target.{{ (effsat.parent_ref ~ '_hk') | q }} = source.{{ (effsat.parent_ref ~ '_hk') | q }}
WHEN MATCHED THEN
