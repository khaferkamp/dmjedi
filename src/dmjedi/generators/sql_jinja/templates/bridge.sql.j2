-- Bridge: {{ bridge.name }}
-- Generated by DMJEDI (query-assist: view, not table)
{%- set path = bridge.path %}

CREATE OR REPLACE VIEW bridge_{{ bridge.name }} AS
SELECT
    {{ path[0] }}_hk
{%- for i in range(1, path|length, 2) %}
    , {{ path[i] }}_hk
    , {{ path[i + 1] }}_hk
{%- endfor %}
FROM {{ path[0] }}
{%- for i in range(1, path|length, 2) %}
JOIN {{ path[i] }}
    ON {{ path[i] }}.{{ path[i - 1] }}_hk = {{ path[i - 1] }}.{{ path[i - 1] }}_hk
JOIN {{ path[i + 1] }}
    ON {{ path[i] }}.{{ path[i + 1] }}_hk = {{ path[i + 1] }}.{{ path[i + 1] }}_hk
{%- endfor %}
;
